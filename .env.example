# API Settings
API_KEY=your_openai_api_key_here
# Optional: Set this if using a different endpoint (e.g. proxy, local model, openrouter)
# API_BASE_URL=https://api.openai.com/v1

# The model to use. You mentioned gpt-5.4-nano, but adjust to whatever is available.
MODEL_NAME=gpt-4o-mini

# Hotkey Settings
# Modifiers can be combined with '+' e.g., shift+alt
HOTKEY_MOD=shift+alt
HOTKEY_KEY=C
